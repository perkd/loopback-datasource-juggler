{
  "name": "@perkd/loopback-datasource-juggler",
  "version": "6.1.0",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "description": "LoopBack DataSource Juggler",
  "keywords": [
    "StrongLoop",
    "LoopBack",
    "DataSource",
    "Connector",
    "Database",
    "Juggler",
    "ORM"
  ],
  "author": "IBM Corp.",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/perkd/loopback-datasource-juggler.git"
  },
  "main": "index.js",
  "types": "index.d.ts",
  "browser": {
    "depd": "./lib/browser.depd.js"
  },
  "scripts": {
    "lint": "eslint .",
    "build": "yarn build-ts-types",
    "build-ts-types": "tsc -p tsconfig.json --outDir dist",
    "pretest": "yarn build",
    "test": "c8 node --require ./test/init.js --test --test-reporter=spec --test-timeout=10000 --test-concurrency=1 \"test/**/*.test.js\"",
    "posttest": "yarn lint",
    "update": "ncu -u -x nanoid",
    "reinstall": "rm -rf node_modules/ && yarn install --immutable"
  },
  "dependencies": {
    "async": "^3.2.6",
    "change-case": "5.4.4",
    "debug": "^4.4.3",
    "depd": "^2.0.0",
    "inflection": "^3.0.2",
    "loopback-connector": "^8.0.0",
    "minimatch": "^10.2.5",
    "nanoid": "3.3.12",
    "neotraverse": "^1.0.1",
    "qs": "^6.15.3",
    "strong-globalize": "^6.0.6",
    "uuid": "11.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/node": "^26.1.0",
    "async-iterators": "^0.2.2",
    "bson-objectid": "^2.0.4",
    "c8": "^11.0.0",
    "eslint": "^10.6.0",
    "eslint-config-loopback": "^14.0.0",
    "loopback-connector-throwing": "file:./test/fixtures/loopback-connector-throwing",
    "typescript": "^6.0.3"
  },
  "packageManager": "yarn@4.17.0",
  "bugs": {
    "url": "https://github.com/perkd/loopback-datasource-juggler/issues"
  },
  "homepage": "https://github.com/perkd/loopback-datasource-juggler#readme",
  "files": [
    "index.js",
    "lib",
    "types",
    "docs.json",
    "intl",
    "README.md"
  ]
}
